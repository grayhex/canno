CANNO_ADMIN_USER=admin
CANNO_ADMIN_PASSWORD=change-me
CANNO_LOG_LEVEL=INFO

# Infrastructure profile
CANNO_DB_ENGINE=sqlite
CANNO_DB_PATH=/data/canno.db

# Prepared for Postgres switch (P2.10)
# CANNO_DB_ENGINE=postgres
# CANNO_DATABASE_URL=postgresql://canno:canno@postgres:5432/canno

# Если используете CANNO_DATABASE_URL для SQLite: предпочитайте sqlite://./canno.db
# (или просто canno.db), а не sqlite:///canno.db.
